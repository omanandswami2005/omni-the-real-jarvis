# ===========================================
# OMNI — Environment Variables Template
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git.
# ===========================================

# --- Google Cloud ---
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# --- Gemini / Vertex AI ---
GOOGLE_GENAI_USE_VERTEXAI=true
# Or use API key for quick local dev:
# GOOGLE_API_KEY=your-gemini-api-key

# --- Firebase ---
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_WEB_API_KEY=your-firebase-web-api-key

# --- E2B Sandbox ---
E2B_API_KEY=your-e2b-api-key

# --- Application ---
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- GCS (Cloud Storage) ---
GCS_BUCKET_NAME=omni-artifacts

# --- MCP Plugin Keys ---
# GitHub MCP (https://github.com/settings/tokens)
GITHUB_PERSONAL_ACCESS_TOKEN=
# Brave Search (https://api.search.brave.com/app/keys — free 2k queries/mo)
BRAVE_API_KEY=
# Slack MCP
SLACK_BOT_TOKEN=
SLACK_TEAM_ID=
# Jules (Google AI coding agent)
JULES_API_KEY=

# --- Native Plugin Keys ---
# Courier (email delivery — https://app.courier.com)
COURIER_API_KEY=
# Resend (email fallback — https://resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=omni@resend.dev

# --- Google OAuth (for Drive, Calendar plugins) ---
# Create OAuth 2.0 credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Secret Manager (production only) ---
# In production, secrets are fetched from Google Secret Manager.
# These env vars are for local dev only.
