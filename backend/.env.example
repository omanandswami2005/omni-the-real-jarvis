# ===========================================
# Omni Backend — Environment Variables
# ===========================================
# Copy to .env:  cp .env.example .env

# --- Google Cloud / Vertex AI ---
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true
AGENT_ENGINE_NAME=omni-agent-engine
USE_AGENT_ENGINE_SESSIONS=true
USE_AGENT_ENGINE_MEMORY_BANK=true
USE_AGENT_ENGINE_CODE_EXECUTION=true
AGENT_ENGINE_SESSION_TTL=604800s
AGENT_ENGINE_SANDBOX_TTL=86400s
# Or for quick local dev with API key:
# GOOGLE_API_KEY=your-gemini-api-key

# --- Firebase ---
FIREBASE_PROJECT_ID=your-firebase-project-id

# --- Firebase Web Client (for scripts/tests only) ---
FIREBASE_WEB_API_KEY=your-firebase-web-api-key
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=your-test-password
FIREBASE_SERVICE_ACCOUNT=path/to/service-account.json

# --- E2B Sandbox ---
E2B_API_KEY=your-e2b-api-key

# --- Model Names ---
# For Vertex AI Live API (recommended, GA)
LIVE_MODEL=gemini-live-2.5-flash-native-audio
# For Gemini Live API (if not using Vertex AI)
# LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
TEXT_MODEL=gemini-2.5-flash

# --- Application ---
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
ENVIRONMENT=development

# --- GCS (Cloud Storage) ---
GCS_BUCKET_NAME=omni-artifacts

# --- URLs (for OAuth callbacks & CORS postMessage) ---
# Set these to your deployed Cloud Run / Firebase Hosting URLs in production
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# --- Google OAuth (for Google Calendar / Drive plugins) ---
# Create at: GCP Console > APIs & Services > Credentials > OAuth 2.0 Client ID
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
